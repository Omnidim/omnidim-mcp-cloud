ENVIRONMENT=development
LOG_LEVEL=info

# Postgres
DATABASE_URL=postgresql+asyncpg://omni:omni@localhost:5433/omni_mcp

# Hosts
PUBLIC_BASE_URL=http://localhost:8000
DASHBOARD_BASE_URL=http://localhost:3000
ODOO_INTERNAL_BASE_URL=http://localhost:8069
ODOO_INTERNAL_SHARED_SECRET=change-me

# OAuth
TOKEN_SIGNING_KEY=replace-with-32-or-more-bytes-of-random
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=7776000

# Telemetry
LOKI_PUSH_URL=
LOKI_LABELS=service=omni-mcp-server,env=development
